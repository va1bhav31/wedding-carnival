# Supabase — copy this file to ".env.local" and fill in your project values.
# Find these in: Supabase Dashboard -> Project Settings -> API

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe for the browser; protected by Row-Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (NEVER prefix with NEXT_PUBLIC) ---
# Supabase secret key (sb_secret_...) from Dashboard -> Settings -> API.
# Bypasses RLS; used only inside admin server actions. Never sent to the browser.
SUPABASE_SECRET_KEY=

# Comma-separated list of emails allowed into the /admin panel.
# e.g. ADMIN_EMAILS=you@example.com,partner@example.com
ADMIN_EMAILS=
